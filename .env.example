# Development
VITE_API_URL=http://localhost:5000/api

# Production (replace with your production API URL)
# For same-domain Vercel deployment (recommended), leave unset so `/api` is used automatically.
# If using an external API domain, set this to your backend URL:
# VITE_API_URL=https://demiqra.app/api

# Razorpay Configuration
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
